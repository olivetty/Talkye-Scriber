# ╔══════════════════════════════════════════════════════════════╗
# ║  TALKYE MEET — Command Center                               ║
# ║  Real-time voice translation for video calls                 ║
# ║  Evolved from olivetty/dictate prototype                     ║
# ╚══════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────┐
# │  1. API KEYS                                                 │
# └──────────────────────────────────────────────────────────────┘

GROQ_API_KEY=gsk_...
# Free at https://console.groq.com
# Used by: translation (Groq LLM)

DEEPGRAM_API_KEY=...
# Used by: streaming STT (Deepgram Nova-3)
# Get at https://console.deepgram.com


# ┌──────────────────────────────────────────────────────────────┐
# │  2. DEEPGRAM STT — streaming speech-to-text                  │
# │  Docs: docs/live-translation.md                              │
# └──────────────────────────────────────────────────────────────┘

STT_LANGUAGE=ro                     # ro | en | auto
DEEPGRAM_ENDPOINTING=500            # ms silence → finalize (300=fast, 500=natural, 800=long)
DEEPGRAM_UTTERANCE_END=1500         # ms gap → UtteranceEnd event


# ┌──────────────────────────────────────────────────────────────┐
# │  3. TRANSLATION — Groq LLM                                   │
# └──────────────────────────────────────────────────────────────┘

TRANSLATE_FROM=ro                   # source language name for LLM prompt
TRANSLATE_TO=en                     # target language name for LLM prompt
TRANSLATE_MODEL=llama-3.3-70b-versatile  # Groq model (~150-300ms per request)


# ┌──────────────────────────────────────────────────────────────┐
# │  4. ACCUMULATOR — balances latency vs translation quality     │
# └──────────────────────────────────────────────────────────────┘

ACCUM_FIRST_WORDS=4                 # first flush at 4 words (fast initial response)
ACCUM_MIN_WORDS=8                   # subsequent flushes at 8+ words (better translations)
# Speech end (pause/utterance_end) always flushes immediately


# ┌──────────────────────────────────────────────────────────────┐
# │  5. STT BACKEND — local or cloud                             │
# └──────────────────────────────────────────────────────────────┘

STT_BACKEND=parakeet                # deepgram = cloud streaming | parakeet = local NVIDIA TDT
PARAKEET_MODEL=models/parakeet-tdt   # path to ONNX model files
VAD_MODEL=models/silero_vad.onnx    # Silero VAD V5 — download from https://huggingface.co/onnx-community/silero-vad


# ┌──────────────────────────────────────────────────────────────┐
# │  6. POCKET TTS — voice cloning, local CPU, free              │
# └──────────────────────────────────────────────────────────────┘

POCKET_VOICE=voices/oliver.wav
# Built-in voices: alba, marius, javert, jean, fantine, cosette
# Voice clone: path to .wav (record with prototype/record_voice.sh)
# Fast clone: path to .safetensors
POCKET_SPEED=1.0                    # 1.0=normal, 1.2=faster, 0.8=slower


# ┌──────────────────────────────────────────────────────────────┐
# │  7. AUDIO — Linux hardware config                            │
# └──────────────────────────────────────────────────────────────┘

AUDIO_SOURCE=effect_output.voice_enhance  # PipeWire/PulseAudio source (RNNoise enhanced mic)
# Leave empty for system default mic

# Virtual device names (created automatically for call app integration)
VIRTUAL_SPEAKER_NAME=live_interp_out
VIRTUAL_MIC_NAME=live_interp_in
