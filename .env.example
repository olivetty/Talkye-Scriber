# ═══════════════════════════════════════════════════════════════
# Talkye Meet — Command Center
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════

# ── API Keys ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=your_groq_key_here

# ── Deepgram STT ──────────────────────────────────────────────
# Language for speech recognition (ro, en, auto)
STT_LANGUAGE=ro
# Endpointing: ms of silence before finalizing a phrase (lower = faster, more fragments)
DEEPGRAM_ENDPOINTING=500
# Utterance end: ms of silence before ending an utterance (triggers flush)
DEEPGRAM_UTTERANCE_END=1500

# ── Translation ───────────────────────────────────────────────
# Source → Target language pair
TRANSLATE_FROM=ro
TRANSLATE_TO=en
# Groq model for translation
TRANSLATE_MODEL=llama-3.3-70b-versatile

# ── Accumulator ───────────────────────────────────────────────
# Min words before first flush (lower = faster first response)
ACCUM_FIRST_WORDS=4
# Min words for subsequent flushes
ACCUM_MIN_WORDS=8

# ── TTS (Pocket TTS) ─────────────────────────────────────────
# Voice: built-in name OR path to .wav file for voice cloning
POCKET_VOICE=alba
# Playback speed multiplier
POCKET_SPEED=1.0

# ── Audio (Linux) ─────────────────────────────────────────────
# PulseAudio source for mic input (leave empty for default)
AUDIO_SOURCE=
# Virtual device names (created automatically)
VIRTUAL_SPEAKER_NAME=live_interp_out
VIRTUAL_MIC_NAME=live_interp_in
